<% layout('/layouts/boilerplate') %>

<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">

      <div class="card shadow rounded-4 text-center p-4">

        <!-- Icon -->
        <div class="mb-3">
          <i class="fa-solid fa-circle-xmark text-danger" style="font-size: 60px;"></i>
        </div>

        <!-- Title -->
        <h3 class="text-danger">Payment Failed</h3>

        <!-- Message -->
        <p class="mt-3">
          Oops! Your payment could not be completed.
        </p>

        <p class="text-muted">
          Please try again or choose a different payment method.
        </p>

        <!-- Optional error message -->
        <% if (error) { %>
          <div class="alert alert-danger mt-3">
            <%= errorMessage %>
          </div>
        <% } %>

        <!-- Actions -->
        <div class="mt-4 d-flex justify-content-center gap-3">

          <a href="/booking/<%= id %>" class="btn btn-outline-danger">
            Try Again
          </a>

          <a href="/bookings" class="btn btn-dark">
            My Bookings
          </a>

        </div>

      </div>

    </div>
  </div>
</div>