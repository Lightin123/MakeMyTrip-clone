<% layout('/layouts/boilerplate') %>

<div class="row justify-content-center">
  <div class="col-md-6 mt-5">

    <div class="card shadow rounded-4 p-4">

      <h3 class="text-center mb-4"><i class="fa-solid fa-house"></i> Booking Details</h3>

      <form method="POST" action="/booking/<%= id %>/pay">

        <!-- Rooms -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Number of Rooms</label>
          <input 
            class="form-control" 
            name="booking[rooms]" 
            type="number" 
            min="1" 
            placeholder="Enter rooms" 
            required>
        </div>

        <!-- Date Range -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Select Dates</label>
          <input 
            type="text" 
            id="dateRange" 
            class="form-control" 
            placeholder="Choose your stay dates"
            name="booking[date]" 
            required>
        </div>

        <!-- Hidden fields -->
        <input type="hidden" name="booking[startDate]" id="startDate">
        <input type="hidden" name="booking[endDate]" id="endDate">

        <!-- Guests -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Number of Guests</label>
          <input 
            class="form-control" 
            name="booking[guests]" 
            type="number" 
            min="1" 
            placeholder="Enter guests"
            required>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn-success w-100 mt-3">
          Proceed to Payment
        </button>

      </form>

    </div>

  </div>
</div>

<script>
  const bookings = JSON.parse('<%- JSON.stringify(bookings || []) %>');
  const totalRooms = <%= totalRooms %>;
  const roomsInput = document.querySelector("[name='booking[rooms]']");
 function isAvailable(date, requestedRooms) {
  let roomsUsed = 0;

  bookings.forEach(b => {
    const start = new Date(b.startDate);
    const end = new Date(b.endDate);

    if (start <= date && date < end) {
      roomsUsed += b.rooms;
    }
  });

  return roomsUsed + requestedRooms <= totalRooms;
}
function getUnavailableDates(requestedRooms) {
  const result = [];
  const todayStr = new Date().toISOString().split('T')[0];
  const baseDate = new Date(todayStr); // Forces UTC Midnight

  for (let i = 0; i < 90; i++) { // Check up to 90 days ahead
    const d = new Date(baseDate.getTime() + i * 24 * 60 * 60 * 1000);

    if (!isAvailable(d, requestedRooms)) {
      result.push(d.toISOString().split("T")[0]);
    }
  }

  return result;
}
let fp;

function initPicker(disabledDates) {
  console.log("working");
  fp = flatpickr("#dateRange", {
    mode: "range",
    minDate: "today",
    showMonths: 2,
    disable: disabledDates,
    onChange: function (selectedDates) {
    if (selectedDates.length === 2) {
      if (selectedDates[0].getTime() === selectedDates[1].getTime()) {
          fp.clear();
          alert("Minimum stay is 1 night. Please select a valid range.");
          return;
      }
      const format = (date) => {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        return `${year}-${month}-${day}`;
      };

      document.getElementById("startDate").value = format(selectedDates[0]);
      document.getElementById("endDate").value = format(selectedDates[1]);
    }
  }
  });
}
roomsInput.addEventListener("change", () => {
  const rooms = parseInt(roomsInput.value);
  if (isNaN(rooms) || rooms < 1) {
    alert("Please enter a valid number of rooms.");
    roomsInput.value = "";
    return;
  }

  const disabled = getUnavailableDates(rooms);

  initPicker(disabled);
});
initPicker(getUnavailableDates(1));

</script>