<% layout('/layouts/boilerplate') %>

<div class="row justify-content-center">
  <div class="col-md-6 mt-5">

    <div class="card shadow rounded-4 p-4">
      
      <h3 class="mb-4 text-center"><i class="fa-solid fa-credit-card"></i> Payment Details</h3>

      <div class="d-flex justify-content-between border-bottom py-2">
        <span class="text-muted">From</span>
        <span><%= bookingData.startDate %></span>
      </div>

      <div class="d-flex justify-content-between border-bottom py-2">
        <span class="text-muted">To</span>
        <span><%= bookingData.endDate %></span>
      </div>

      <div class="d-flex justify-content-between border-bottom py-2">
        <span class="text-muted">Guests</span>
        <span><%= bookingData.guests %></span>
      </div>
      <div class="d-flex justify-content-between border-bottom py-2">
        <span class="text-muted">Rooms</span>
        <span><%= bookingData.rooms %></span>
      </div>

      <div class="d-flex justify-content-between py-3">
        <span class="fw-bold">Total Price</span>
        <span class="fw-bold text-success">
          ₹ <%= (listPrice * 1.18*bookingData.rooms).toFixed(2) %>
        </span>
      </div>

      <button class="btn btn-success w-100 mt-3">
        Proceed to Pay
      </button>

    </div>

  </div>
</div>