<% layout('/layouts/boilerplate') %>

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-6 text-center">
        <div class="card shadow rounded-4 p-5 border-0 bg-white">
            <div class="mb-4">
                <i class="fa-solid fa-circle-check text-success" style="font-size: 80px; filter: drop-shadow(0 4px 6px rgba(25, 135, 84, 0.3));"></i>
            </div>
            
            <h1 class="fw-bold text-dark mb-3">Booking Confirmed!</h1>
            
            <p class="text-muted fs-5 mb-2">
                Your stay at <strong class="text-dark"><%= listing.title %></strong> has been successfully booked.
            </p>
            
            <p class="text-muted mb-4">
                Get ready for your trip! You can view your destination details or explore more amazing places below.
            </p>
            
            <hr class="mb-4 w-75 mx-auto text-muted">
            
            <div class="d-flex justify-content-center gap-3 mt-4 flex-wrap">
                <a href="/listings/<%= listing._id %>" class="btn btn-outline-dark px-4 py-2 rounded-pill fw-semibold shadow-sm">
                    <i class="fa-solid fa-arrow-left me-2"></i> Back to Listing
                </a>
                <a href="/listings" class="btn btn-danger px-4 py-2 rounded-pill fw-semibold shadow-sm" style="background-color: #fe424d; border-color: #fe424d;">
                    <i class="fa-solid fa-compass me-2"></i> Explore More
                </a>
            </div>
        </div>
    </div>
</div>
